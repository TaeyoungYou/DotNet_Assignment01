@{
    ViewData["title"] = "Event Manager";
}
@model List<Assignment01.Models.Event>
@section Styles {
    <link rel="stylesheet" href="~/css/events.css" />
}

<h1>@ViewData["title"]</h1>
<p>Select an event to manage attendees.</p>

<table>
    <thead>
        <th>Title</th>
        <th>Date</th>
        <th>Location</th>
        <th></th>
    </thead>
    <tbody>
        @foreach(var e in Model){
            <tr>
                <td>@e.Title</td>
                <td>@e.Date.ToString("yyyy-MM-dd")</td>
                <td>@e.Location</td>
                <td>
                    <a asp-action="ManageAttendees" asp-controller="Home" asp-route-id="@e.Id">Manage Attendees</a>
                </td>
            </tr>
        }
    </tbody>
</table>